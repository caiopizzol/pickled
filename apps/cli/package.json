{
  "name": "@pickled-dev/cli",
  "version": "0.15.0",
  "description": "Test what agents actually understand about your product",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "pickled": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --external @anthropic-ai/claude-agent-sdk",
    "release": "semantic-release"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "chalk": "^5.6.2",
    "@anthropic-ai/claude-agent-sdk": "^0.3.0"
  },
  "devDependencies": {
    "@pickled-dev/config": "workspace:*",
    "@pickled-dev/core": "workspace:*",
    "semantic-release": "^25.0.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "semantic-release-ai-notes": "^0.3.0"
  }
}
